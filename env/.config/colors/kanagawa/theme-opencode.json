{
    "$schema": "https://opencode.ai/theme.json",
    "defs": {
        "violet": "#957FB8",
        "blue": "#7FB4CA",
        "green": "#98BB6C",
        "orange": "#FFA066",
        "yellow": "#C0A36E",
        "teal": "#7AA89F",
        "cyan": "#7E9CD8",
        "red": "#C34043",
        "attribute": "#7AA89F",

        "fg": "#DCD7BA",
        "muted": "#727169",
        "comment": "#727169",
        "subtle": "#54546D",
        "dim": "#54546D",

        "bg": "#1F1F28",
        "bg_dim": "#16161D",
        "surface": "#2A2A37",
        "overlay": "#363646",

        "highlight_low": "#2A2A37",
        "highlight_med": "#363646",
        "highlight_high": "#54546D",

        "diff_add": "#2B3328",
        "diff_change": "#252535",
        "diff_delete": "#43242B",
        "diff_text": "#2D4F67"
    },
    "theme": {
        "primary": {
            "dark": "cyan",
            "light": "cyan"
        },
        "secondary": {
            "dark": "teal",
            "light": "teal"
        },
        "accent": {
            "dark": "violet",
            "light": "violet"
        },
        "error": {
            "dark": "red",
            "light": "red"
        },
        "warning": {
            "dark": "yellow",
            "light": "yellow"
        },
        "success": {
            "dark": "green",
            "light": "green"
        },
        "info": {
            "dark": "blue",
            "light": "blue"
        },
        "text": {
            "dark": "fg",
            "light": "fg"
        },
        "textMuted": {
            "dark": "subtle",
            "light": "subtle"
        },
        "background": {
            "dark": "bg",
            "light": "bg"
        },
        "backgroundPanel": {
            "dark": "surface",
            "light": "surface"
        },
        "backgroundElement": {
            "dark": "overlay",
            "light": "overlay"
        },
        "border": {
            "dark": "overlay",
            "light": "overlay"
        },
        "borderActive": {
            "dark": "highlight_high",
            "light": "highlight_high"
        },
        "borderSubtle": {
            "dark": "highlight_med",
            "light": "highlight_med"
        },
        "diffAdded": {
            "dark": "green",
            "light": "green"
        },
        "diffRemoved": {
            "dark": "red",
            "light": "red"
        },
        "diffContext": {
            "dark": "subtle",
            "light": "subtle"
        },
        "diffHunkHeader": {
            "dark": "cyan",
            "light": "cyan"
        },
        "diffHighlightAdded": {
            "dark": "green",
            "light": "green"
        },
        "diffHighlightRemoved": {
            "dark": "red",
            "light": "red"
        },
        "diffAddedBg": {
            "dark": "diff_add",
            "light": "diff_add"
        },
        "diffRemovedBg": {
            "dark": "diff_delete",
            "light": "diff_delete"
        },
        "diffContextBg": {
            "dark": "bg_dim",
            "light": "bg_dim"
        },
        "diffLineNumber": {
            "dark": "dim",
            "light": "dim"
        },
        "diffAddedLineNumberBg": {
            "dark": "diff_add",
            "light": "diff_add"
        },
        "diffRemovedLineNumberBg": {
            "dark": "diff_delete",
            "light": "diff_delete"
        },
        "markdownText": {
            "dark": "fg",
            "light": "fg"
        },
        "markdownHeading": {
            "dark": "cyan",
            "light": "cyan"
        },
        "markdownLink": {
            "dark": "blue",
            "light": "blue"
        },
        "markdownLinkText": {
            "dark": "cyan",
            "light": "cyan"
        },
        "markdownCode": {
            "dark": "green",
            "light": "green"
        },
        "markdownBlockQuote": {
            "dark": "muted",
            "light": "muted"
        },
        "markdownEmph": {
            "dark": "fg",
            "light": "fg"
        },
        "markdownStrong": {
            "dark": "fg",
            "light": "fg"
        },
        "markdownHorizontalRule": {
            "dark": "dim",
            "light": "dim"
        },
        "markdownListItem": {
            "dark": "blue",
            "light": "blue"
        },
        "markdownListEnumeration": {
            "dark": "blue",
            "light": "blue"
        },
        "markdownImage": {
            "dark": "blue",
            "light": "blue"
        },
        "markdownImageText": {
            "dark": "cyan",
            "light": "cyan"
        },
        "markdownCodeBlock": {
            "dark": "fg",
            "light": "fg"
        },
        "syntaxComment": {
            "dark": "comment",
            "light": "comment"
        },
        "syntaxKeyword": {
            "dark": "violet",
            "light": "violet"
        },
        "syntaxFunction": {
            "dark": "cyan",
            "light": "cyan"
        },
        "syntaxVariable": {
            "dark": "fg",
            "light": "fg"
        },
        "syntaxString": {
            "dark": "green",
            "light": "green"
        },
        "syntaxNumber": {
            "dark": "orange",
            "light": "orange"
        },
        "syntaxType": {
            "dark": "teal",
            "light": "teal"
        },
        "syntaxOperator": {
            "dark": "muted",
            "light": "muted"
        },
        "syntaxPunctuation": {
            "dark": "muted",
            "light": "muted"
        }
    }
}
