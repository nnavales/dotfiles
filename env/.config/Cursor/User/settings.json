{
    "window.commandCenter": true,
    "git.openRepositoryInParentFolders": "never",
    "svelte.enable-ts-plugin": true,
    "workbench.colorTheme": "Rosé Pine Moon (no italics)",
    "editor.fontFamily": "JetBrains Mono",
    "editor.fontWeight": 600,
    "editor.fontSize": 17,
    "editor.cursorBlinking": "solid",
    "editor.scrollbar.vertical": "hidden",
    "editor.scrollbar.horizontal": "hidden",
    "editor.scrollbar.verticalScrollbarSize": 0,
    "editor.scrollbar.horizontalScrollbarSize": 0,
    "terminal.integrated.fontSize": 16,
    "window.zoomLevel": 0.2,
    "workbench.fontAliasing": "antialiased",
    "editor.minimap.enabled": false,
    "breadcrumbs.enabled": false,
    "workbench.statusBar.visible": true,
    "editor.lineNumbers": "on",
    "editor.rulers": [],
    "editor.renderWhitespace": "none",
    "editor.renderLineHighlight": "line",
    "editor.hideCursorInOverviewRuler": true,
    "editor.overviewRulerBorder": false,
    "editor.folding": false,
    "editor.glyphMargin": false,
    "editor.lineDecorationsWidth": 20,
    "editor.lineHeight": 0,
    "workbench.editor.showTabs": "single",
    "workbench.editor.tabSizing": "shrink",
    "workbench.editor.labelFormat": "short",
    "workbench.editor.tabCloseButton": "right",
    "workbench.tree.indent": 8,
    "workbench.iconTheme": "material-icon-theme",
    "editor.semanticHighlighting.enabled": false,
    "editor.bracketPairColorization.enabled": true,
    "editor.guides.bracketPairs": false,
    "editor.guides.highlightActiveIndentation": false,
    "editor.guides.indentation": false,

    "workbench.colorCustomizations": {
        "editor.background": "#16181B",
        "sideBar.background": "#1a1d23",
        "panel.background": "#1a1d23",
        "activityBar.background": "#1e2126",
        "editorGroupHeader.tabsBackground": "#1a1d23",
