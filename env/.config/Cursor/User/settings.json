        "tab.activeBackground": "#16181B",
        "editor.selectionBackground": "#33364a4D",
        "editor.selectionHighlightBackground": "#33364a4D",
        "list.activeSelectionBackground": "#33364a4D",
        "list.inactiveSelectionBackground": "#33364a4D",
        "statusBar.background": "#005f5f",
        "statusBar.noFolderBackground": "#005f5f",
        "statusBar.debuggingBackground": "#005f5f",
        "statusBar.foreground": "#ffffff",
        "statusBarItem.remoteBackground": "#1a1d23",
