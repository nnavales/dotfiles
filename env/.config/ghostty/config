command = "tmux new-session -A -s default"

window-padding-x = 120,120
window-decoration = false
resize-overlay = never
background-opacity = 0.95
background-blur-radius = 20

confirm-close-surface = false
mouse-hide-while-typing = true

theme = rozefine.conf
font-family = IoskeleyMonoTerm Nerd Font
font-size = 12.5
font-style = Medium

cursor-style = block
cursor-style-blink = false

keybind=alt+one=unbind
keybind=alt+two=unbind
keybind=alt+three=unbind
keybind=alt+four=unbind
keybind=alt+five=unbind
keybind=alt+six=unbind
keybind=alt+seven=unbind
keybind=alt+eight=unbind
keybind=alt+nine=unbind

keybind = ctrl+up=increase_font_size:1
keybind = ctrl+down=decrease_font_size:1
