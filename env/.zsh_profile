export XDG_CONFIG_HOME=$HOME/.config
export DEV_ENV=$HOME/personal/dev
export DEV_ENV_HOME="$HOME/personal/dev"
export STARSHIP_CONFIG="$HOME/.config/starship/starship.toml"
export GOPATH="$HOME/go"
export GOROOT=/usr/lib/go

addToPath() {
    if [[ "$PATH" != *"$1"* ]]; then
        export PATH=$PATH:$1
    fi
}

addToPathFront() {
    if [[ ! -z "$2" ]] || [[ "$PATH" != *"$1"* ]]; then
        export PATH=$1:$PATH
    fi
}

addToPathFront $HOME/.local/apps
addToPathFront $HOME/.local/scripts
addToPathFront $HOME/.local/bin
addToPath $HOME/.uv/bin
addToPath $HOME/.cargo/bin
addToPath $HOME/.bun/bin
addToPath $HOME/.opencode/bin
addToPath $GOROOT/bin:$GOPATH/bin
