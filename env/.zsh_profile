export XDG_CONFIG_HOME="$HOME/.config"
export DEV_ENV="$HOME/personal/dev"
export STARSHIP_CONFIG="$HOME/.config/starship/starship.toml"
export GOPATH="$HOME/go"
export GOROOT="/usr/lib/go"

typeset -U path

path=(
  "$HOME/.local/apps"
  "$HOME/.local/scripts"
  "$HOME/.local/bin"
  $path
)

path+=(
  "$HOME/.uv/bin"
  "$HOME/.cargo/bin"
  "$HOME/.bun/bin"
  "$HOME/.opencode/bin"
  "$GOROOT/bin"
  "$GOPATH/bin"
)
