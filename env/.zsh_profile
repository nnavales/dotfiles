export DEV_ENV="$HOME/personal/dev"
export GOPATH="$HOME/go"
export GOROOT="/usr/lib/go"
export ANDROID_HOME="$HOME/Android/Sdk"

typeset -U path

path=(
  "$HOME/.local/apps"
  "$HOME/.local/scripts"
  "$HOME/.local/bin"
  $path
)

path+=(
  "$HOME/.uv/bin"
  "$HOME/.cargo/bin"
  "$HOME/.bun/bin"
  "$HOME/.opencode/bin"
  "$GOROOT/bin"
  "$GOPATH/bin"
  "$ANDROID_HOME/emulator"
  "$ANDROID_HOME/platform-tools"
  "$ANDROID_HOME/cmdline-tools/latest/bin"
)
