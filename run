#!/usr/bin/env bash

if [[ $EUID -ne 0 ]]; then
    echo "The script needs root privileges."
    exec sudo DEV_ENV="$DEV_ENV" "$0" "$@"
fi

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" &>/dev/null && pwd)"

DEV_ENV="${DEV_ENV:-$(pwd)}"
export DEV_ENV

grep=""
dry_run="0"

while [[ $# -gt 0 ]]; do
    echo "ARG: \"$1\""
    if [[ "$1" == "--dry" ]]; then
        dry_run="1"
    else
        grep="$1"
    fi
    shift
done

log() {
    if [[ $dry_run == "1" ]]; then
        echo "[DRY_RUN]: $1"
    else
        echo "$1"
    fi
}

log "RUN: env: $DEV_ENV -- grep: $grep"

order_file="$script_dir/runs/ORDER"
if [[ ! -f "$order_file" ]]; then
    echo "ERROR: $order_file not found"
    exit 1
fi

while IFS= read -r script_name || [[ -n "$script_name" ]]; do
    [[ -z "$script_name" || "$script_name" == \#* ]] && continue

    s="$script_dir/runs/$script_name"

    if [[ ! -x "$s" ]]; then
        log "skipping (not executable): $s"
        continue
    fi

    if [[ -n "$grep" ]] && ! echo "$script_name" | grep -q "$grep"; then
        log "grep \"$grep\" filtered out $s"
        continue
    fi

    log "running script: $s"

    if [[ $dry_run == "0" ]]; then
        "$s"
    fi
done <"$order_file"
